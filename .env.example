# Travel Trend Detector — API Keys
# Copy this file to .env and fill in your keys

# SerpAPI (Google Trends + Google Search)
# Get your key at: https://serpapi.com/users/sign_up
TTD_SERPAPI_KEY=

# Apify (Instagram hashtag scraping)
# Get your token at: https://console.apify.com/sign-up → Settings → Integrations
TTD_APIFY_TOKEN=

# Anthropic Claude API (semantic analysis)
# Get your key at: https://console.anthropic.com → Settings → API Keys
TTD_ANTHROPIC_KEY=
